<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_sync_devices" model="ir.cron">
            <field name="name">SoftLife: Huaxin device sync</field>
            <field name="model_id" ref="model_softlife_huaxin_client"/>
            <field name="state">code</field>
            <field name="code">model._cron_sync_devices()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
        <record id="cron_pull_temperatures" model="ir.cron">
            <field name="name">SoftLife: Huaxin temperature pull</field>
            <field name="model_id" ref="model_softlife_huaxin_client"/>
            <field name="state">code</field>
            <field name="code">model._cron_pull_temperatures()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
